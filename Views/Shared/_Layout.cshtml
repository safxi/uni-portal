<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HITEC Smart University Portal</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2=family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8fafc;
            color: #0f172a;
        }
        .navbar-custom {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            box-shadow: 0 4px 30px rgba(0,0,0,0.05);
        }
        .nav-link-custom {
            color: #94a3b8 !important;
            font-weight: 500;
            transition: all 0.2s ease;
        }
        .nav-link-custom:hover {
            color: #38bdf8 !important;
            transform: translateY(-1px);
        }
        .premium-card {
            border: none;
            border-radius: 16px;
            background: #ffffff;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .premium-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }
        .gradient-btn {
            background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        .gradient-btn:hover {
            background: linear-gradient(135deg, #1d4ed8 0%, #1e40af 100%);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(29, 78, 216, 0.3);
        }
        footer {
            background-color: #0f172a;
            color: #94a3b8;
        }
    </style>
</head>
<body>
    <header class="animate__animated animate__fadeInDown">
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom py-3">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4 text-white" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-mortarboard-fill text-info me-2"></i>HiSUP <span class="fs-6 text-white-50 fw-light">HITEC Portal</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom px-3" asp-controller="Home" asp-action="Index"><i class="bi bi-house me-1"></i> Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom px-3" asp-controller="Admin" asp-action="Index"><i class="bi bi-shield-lock me-1"></i> Admin Portal</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom px-3" asp-controller="Faculty" asp-action="Index"><i class="bi bi-person-workspace me-1"></i> Faculty Panel</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom px-3" asp-controller="Student" asp-action="Dashboard"><i class="bi bi-person-badge me-1"></i> Student Area</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom px-3" asp-controller="Student" asp-action="ReportCard"><i class="bi bi-award-fill me-1"></i> Transcript Center</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom px-3" asp-controller="Library" asp-action="Search"><i class="bi bi-search me-1"></i> Library Gateway</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container py-5">
        @RenderBody()
    </main>

    <footer class="footer text-center py-4 text-white-50 mt-5 border-top border-secondary">
        <div class="container">
            HiSUP Enterprise Academic Engine &copy; 2026 | Deployed by Saif Ur Rehman
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
