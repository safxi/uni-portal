@using System.Data
@model DataTable
<div class="container mt-4 animate__animated animate__fadeIn">
    <h2 class="fw-bold text-dark mb-4"><i class="bi bi-award-fill text-warning me-2"></i>My Real-time Enrolled Courses & Attendance Portal</h2>
    <div class="row g-4">
        <div class="col-lg-12">
            <div class="card premium-card p-4 shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Code</th>
                                <th>Course Title Description</th>
                                <th>Assigned Teacher</th>
                                <th class="text-center">Obtained Marks</th>
                                <th class="text-center">My Attendance Log</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (DataRow row in Model.Rows)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@row["CourseCode"]</span></td>
                                    <td class="fw-semibold">@row["CourseTitle"]</td>
                                    <td class="text-primary">@row["Faculty"]</td>
                                    <td class="text-center fw-bold font-monospace text-success">@row["ObtainedMarks"] / 100</td>
                                    <td class="text-center">
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar bg-info text-dark fw-bold" role="progressbar" style="width: @row["Attendance"]%;">@row["Attendance"]%</div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
