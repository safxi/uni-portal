@{
    ViewData["Title"] = "Welcome Gateway";
}

<div class="container mt-5">
    <div class="p-5 mb-5 text-white rounded-4 shadow-lg animate__animated animate__zoomIn" style="background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%); position: relative; overflow: hidden;">
        <div class="py-4 text-center">
            <span class="badge bg-info text-dark mb-3 px-3 py-2 fw-semibold animate__animated animate__flash animate__delay-1s">SYSTEM LIVE ON AWS EC2</span>
            <h1 class="display-3 fw-bold tracking-tight">HITEC Smart University Portal</h1>
            <p class="col-md-10 mx-auto fs-5 text-white-50 mt-3">An enterprise grade Academic Ledger Management Ecosystem optimized with robust multi-layered database indexing, column encryption, and ACID transactions.</p>
            <div class="d-grid gap-3 d-sm-flex justify-content-sm-center mt-4">
                <a asp-controller="Student" asp-action="Dashboard" class="btn gradient-btn-primary btn-lg px-5 py-3 shadow"><i class="bi bi-shield-lock me-2"></i> Access Student Console</a>
                <a asp-controller="Library" asp-action="Search" class="btn btn-outline-light btn-lg px-5 py-3"><i class="bi bi-search me-2"></i> Library Search Engine</a>
            </div>
        </div>
    </div>

    <div class="row g-4 text-start">
        <div class="col-md-4 animate__animated animate__fadeInUp animate__delay-1s">
            <div class="card premium-card h-100 p-4">
                <div class="card-body">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary rounded-3 p-3 d-inline-block mb-3">
                        <i class="bi bi-shield-check fs-3"></i>
                    </div>
                    <h4 class="fw-bold">Security Integration</h4>
                    <p class="text-muted">High-security schemas like configurations, transaction logs, and tokens are locked using state-of-the-art backend sanitization parameters.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 animate__animated animate__fadeInUp animate__delay-1s" style="animation-delay: 0.3s;">
            <div class="card premium-card h-100 p-4">
                <div class="card-body">
                    <div class="icon-box bg-success bg-opacity-10 text-success rounded-3 p-3 d-inline-block mb-3">
                        <i class="bi bi-lightning-charge fs-3"></i>
                    </div>
                    <h4 class="fw-bold">Atomic Controls</h4>
                    <p class="text-muted">Course enrollment seat assignments and finance clearing triggers run explicitly under atomic database constraints to ensure concurrency blocks.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 animate__animated animate__fadeInUp animate__delay-1s" style="animation-delay: 0.6s;">
            <div class="card premium-card h-100 p-4">
                <div class="card-body">
                    <div class="icon-box bg-warning bg-opacity-10 text-warning rounded-3 p-3 d-inline-block mb-3">
                        <i class="bi bi-cloud-arrow-up fs-3"></i>
                    </div>
                    <h4 class="fw-bold">High Availability Hosting</h4>
                    <p class="text-muted">Deployed natively inside Amazon Linux architecture utilizing systemd service workers and continuous reverse Nginx topologies.</p>
                </div>
            </div>
        </div>
    </div>
</div>
