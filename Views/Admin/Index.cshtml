@using HiSUP.Data
<div class="container mt-4 animate__animated animate__fadeIn">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm animate__animated animate__bounceIn">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="row g-4">
        <!-- Add New Student Panel -->
        <div class="col-md-6">
            <div class="card premium-card p-4 border-top border-primary border-4 shadow-sm">
                <h4 class="fw-bold text-primary mb-3"><i class="bi bi-person-plus-fill me-2"></i>Onboard New Student</h4>
                <form asp-action="CreateStudent" method="post">
                    <div class="mb-3"><label class="form-label small fw-bold">First Name</label><input type="text" name="firstName" class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label small fw-bold">Last Name</label><input type="text" name="lastName" class="form-control" required /></div>
                    <div class="mb-3"><label class="form-label small fw-bold">University Email Target</label><input type="email" name="email" class="form-control" required /></div>
                    <button type="submit" class="btn btn-primary w-100 fw-bold">Provision Student Identity</button>
                </form>
            </div>
        </div>

        <!-- Allocation Engine Panel -->
        <div class="col-md-6">
            <div class="card premium-card p-4 border-top border-success border-4 shadow-sm">
                <h4 class="fw-bold text-success mb-3"><i class="bi bi-journal-bookmark-fill me-2"></i>Course Allocation Manager</h4>
                <form asp-action="AssignCourse" method="post">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Select Active Course Node</label>
                        <select name="course" class="form-select">
                            @foreach(var c in DatabaseRepository.GlobalCourses){ <option>@c</option> }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Assign Faculty Resource</label>
                        <select name="faculty" class="form-select">
                            @foreach(var f in DatabaseRepository.GlobalFaculty){ <option>@f</option> }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Target Student Identity Mapping</label>
                        <select name="studentId" class="form-select">
                            @foreach(var s in DatabaseRepository.Students){ <option value="@s["ID"]">@s["Name"] (ID: @s["ID"])</option> }
                        </select>
                    </div>
                    <button type="submit" class="btn btn-success w-100 fw-bold">Lock Resource Matrix Map</button>
                </form>
            </div>
        </div>
    </div>
</div>
